{
  "name": "declarative-sf-metadata",
  "version": "0.1.0",
  "description": "Define Salesforce custom objects and fields declaratively in YAML.",
  "type": "module",
  "bin": {
    "dsfm": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && tsc-alias",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "vitest run e2e/cli",
    "typecheck": "tsc --noEmit",
    "verify:deploy": "bash scripts/verify-deploy.sh"
  },
  "dependencies": {
    "@salesforce/types": "^1.7.3",
    "commander": "^12.1.0",
    "fast-xml-parser": "^4.5.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
